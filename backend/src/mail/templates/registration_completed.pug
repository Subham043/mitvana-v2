doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Verify your account

  body(style="margin:0; padding:0; background-color:#f4f6f8; font-family:Arial, Helvetica, sans-serif;")

    // Wrapper
    table(width="100%" cellpadding="0" cellspacing="0" style="background:#f4f6f8; padding:20px 0;")
      tr
        td(align="center")

          // Main Container
          table(width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:8px; overflow:hidden;")

            // Header
            tr
              td(style="background:#2563eb; color:#ffffff; padding:20px; text-align:center;")
                h2(style="margin:0;") #{appName || 'Mitvana'}

            // Content
            tr
              td(style="padding:24px; text-align:center;")

                p(style="margin:0 0 12px 0; text-align:left;")
                  | Hi #{name},

                h3(style="margin:10px 0 20px 0;")
                  | Verify Your Email

                p(style="margin:0 0 20px 0; color:#4b5563; font-size:14px;")
                  | Use the verification code below to activate your account.

                // ======================
                // OTP CARD
                // ======================
                table(width="100%" cellpadding="0" cellspacing="0")
                  tr
                    td(align="center")

                      table(cellpadding="0" cellspacing="0" style="border:1px solid #e5e7eb; border-radius:8px; padding:16px 24px; background:#f9fafb;")
                        tr
                          td(style="font-size:28px; letter-spacing:6px; font-weight:bold; color:#111; text-align:center;")
                            | #{code}

                // ======================
                // INFO TEXT
                // ======================
                p(style="margin:20px 0 10px 0; font-size:13px; color:#6b7280;")
                  | ⏳ This code will expire on #{expires_at} for security reasons.

                p(style="margin:0; font-size:13px; color:#6b7280;")
                  | If you didn’t create this account, you can safely ignore this email.

            // Footer
            tr
              td(style="padding:16px; background:#f9fafb; font-size:12px; color:#6b7280; text-align:center;")

                p(style="margin:0 0 6px 0;")
                  | Need help? Contact us at 
                  a(
                    href=`mailto:${supportEmail || 'support@mitvana.in'}`
                    style="color:#2563eb; text-decoration:none;"
                  )
                    | #{supportEmail || 'support@mitvana.in'}

                p(style="margin:0;")
                  | © #{new Date().getFullYear()} #{appName || 'Mitvana'}. All rights reserved.