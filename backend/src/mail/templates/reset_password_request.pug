doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Reset Password

  body(style="margin:0; padding:0; background-color:#f4f6f8; font-family:Arial, Helvetica, sans-serif;")

    // Wrapper
    table(width="100%" cellpadding="0" cellspacing="0" style="background:#f4f6f8; padding:20px 0;")
      tr
        td(align="center")

          // Main Container
          table(width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:8px; overflow:hidden;")

            // Header
            tr
              td(style="background:#2563eb; color:#ffffff; padding:20px; text-align:center;")
                h2(style="margin:0;") #{appName || 'Mitvana'}

            // Content
            tr
              td(style="padding:24px;")

                p(style="margin:0 0 12px 0;")
                  | Hi #{name},

                h3(style="margin:10px 0 16px 0;")
                  | 🔐 Reset Your Password

                p(style="margin:0 0 20px 0; color:#4b5563; font-size:14px;")
                  | We received a request to reset your password. Click the button below to set a new password.

                // CTA Button
                div(style="text-align:center; margin:24px 0;")
                  a(
                    href=resetPasswordUrl
                    style="display:inline-block; padding:12px 24px; background:#2563eb; color:#ffffff; text-decoration:none; border-radius:6px; font-weight:bold;"
                  )
                    | Reset Password

                // Expiry Info
                p(style="margin:0 0 12px 0; font-size:13px; color:#6b7280;")
                  | ⏳ This link will expire on #{expires_at}.

                // Security Note
                p(style="margin:0 0 12px 0; font-size:13px; color:#6b7280;")
                  | If you didn’t request a password reset, you can safely ignore this email. Your account remains secure.

                // Fallback Link (very important)
                p(style="margin:16px 0 0 0; font-size:12px; color:#9ca3af; word-break:break-all;")
                  | If the button doesn’t work, copy and paste this link into your browser:
                  br
                  | #{resetPasswordUrl}

            // Footer
            tr
              td(style="padding:16px; background:#f9fafb; font-size:12px; color:#6b7280; text-align:center;")

                p(style="margin:0 0 6px 0;")
                  | Need help? Contact us at 
                  a(
                    href=`mailto:${supportEmail || 'support@mitvana.in'}`
                    style="color:#2563eb; text-decoration:none;"
                  )
                    | #{supportEmail || 'support@mitvana.in'}

                p(style="margin:0;")
                  | © #{new Date().getFullYear()} #{appName || 'Mitvana'}. All rights reserved.