doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Order Update

  body(style="margin:0; padding:0; background-color:#f4f6f8; font-family:Arial, Helvetica, sans-serif;")

    table(width="100%" cellpadding="0" cellspacing="0" style="background:#f4f6f8; padding:20px 0;")
      tr
        td(align="center")

          table(width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:8px; overflow:hidden;")

            // HEADER
            tr
              td(style="background:#2563eb; color:#ffffff; padding:20px; text-align:center;")
                h2(style="margin:0;") #{appName || 'Mitvana'}

            // CONTENT
            tr
              td(style="padding:24px;")

                p(style="margin:0 0 8px 0;") Hi #{name},

                p(style="margin:0 0 16px 0; font-size:14px; color:#4b5563;")
                  | We’ve got an update on your order. Here’s the latest status:

                // STATUS
                if order.status === 'Processing'
                  h3(style="margin:0 0 12px 0; color:#6b7280;") ⏳ Processing

                else if order.status === 'Packed'
                  h3(style="margin:0 0 12px 0; color:#6366f1;") 📦 Packed

                else if order.status === 'Dispatched'
                  h3(style="margin:0 0 12px 0; color:#4f46e5;") 🚀 Dispatched

                else if order.status === 'In Transit'
                  h3(style="margin:0 0 12px 0; color:#2563eb;") 🚚 In Transit

                else if order.status === 'Out for Delivery'
                  h3(style="margin:0 0 12px 0; color:#f59e0b;") 🛵 Out for Delivery

                else if order.status === 'Delivered'
                  h3(style="margin:0 0 12px 0; color:#16a34a;") 🎉 Delivered

                else if order.status === 'On Hold'
                  h3(style="margin:0 0 12px 0; color:#9ca3af;") ⏸ On Hold

                else if order.status === 'Refunded'
                  h3(style="margin:0 0 12px 0; color:#059669;") 💰 Refunded

                else if order.status === 'Failed'
                  h3(style="margin:0 0 12px 0; color:#dc2626;") ⚠️ Order Failed

                else if order.status === 'Payment Failed'
                  h3(style="margin:0 0 12px 0; color:#dc2626;") ❌ Payment Failed

                else if order.status === 'Cancelled by Admin' || order.status === 'Cancelled By user'
                  h3(style="margin:0 0 12px 0; color:#dc2626;") 🛑 Order Cancelled

                // ORDER INFO
                table(width="100%" style="margin-top:10px;")
                  tr
                    td(style="font-size:13px; color:#6b7280;") Order No:
                    td(style="font-size:13px; font-weight:bold; text-align:right;") #{order.orderNumber}

                  tr
                    td(style="font-size:13px; color:#6b7280;") Date:
                    td(style="font-size:13px; font-weight:bold; text-align:right;") #{order.date}

                // MESSAGE
                if order.status === 'Cancelled by Admin' || order.status === 'Cancelled By user'
                  p(style="margin:16px 0 0 0; font-size:14px; color:#4b5563;")
                    | Unfortunately, your order has been cancelled.

                  if order.cancellation_reason
                    p(style="margin:6px 0 0 0; font-size:13px; color:#6b7280;")
                      | Reason: #{order.cancellation_reason}

                else
                  p(style="margin:16px 0 0 0; font-size:14px; color:#4b5563;")
                    | Your order status has been updated. You can track it anytime from your account.

                // ======================
                // EMAIL SAFE BUTTON
                // ======================
                table(width="100%" cellpadding="0" cellspacing="0" style="margin-top:24px;")
                  tr
                    td(align="center")

                      table(role="presentation" cellpadding="0" cellspacing="0")
                        tr
                          td(style="background:#2563eb; border-radius:6px;")
                            a(
                              href=order.status.includes('Cancelled') ? shopUrl : trackUrl
                              style="display:inline-block; padding:12px 20px; font-size:14px; color:#ffffff; text-decoration:none; font-weight:bold;"
                            )
                              | #{order.status.includes('Cancelled') ? 'Continue Shopping' : 'Track Order'}

            // FOOTER
            tr
              td(style="padding:16px; background:#f9fafb; font-size:12px; color:#6b7280; text-align:center;")

                p(style="margin:0 0 6px 0;")
                  | Need help? Contact us at
                  a(
                    href=`mailto:${supportEmail || 'support@mitvana.in'}`
                    style="color:#2563eb; text-decoration:none;"
                  )
                    | #{supportEmail || 'support@mitvana.in'}

                p(style="margin:0;")
                  | © #{new Date().getFullYear()} #{appName || 'Mitvana'}. All rights reserved.