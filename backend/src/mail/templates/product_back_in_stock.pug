doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Product Back In Stock

  body(style="margin:0; padding:0; background-color:#f4f6f8; font-family:Arial, Helvetica, sans-serif;")

    // Wrapper
    table(width="100%" cellpadding="0" cellspacing="0" style="background:#f4f6f8; padding:20px 0;")
      tr
        td(align="center")

          // Main Container
          table(width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:8px; overflow:hidden;")

            // Header
            tr
              td(style="background:#2563eb; color:#ffffff; padding:20px; text-align:center;")
                h2(style="margin:0;") #{appName || 'Mitvana'}

            // Content
            tr
              td(style="padding:24px;")

                p(style="margin:0 0 12px 0;") Hi,

                p(style="margin:0 0 16px 0; font-size:16px; font-weight:bold;")
                  | 🔥 It's Back: #{product.title}

                p(style="margin:0 0 20px 0; color:#4b5563;")
                  | You showed interest earlier—great news! This product is back in stock, but it may sell out again quickly.

                // ======================
                // PRODUCT CARD
                // ======================
                table(width="100%" cellpadding="0" cellspacing="0")
                  tr
                    td(align="center")

                      table(width="100%" cellpadding="0" cellspacing="0" style="max-width:400px; border:1px solid #e5e7eb; border-radius:8px; padding:16px; background:#ffffff;")

                        // Badge
                        tr
                          td(align="center" style="padding-bottom:8px;")
                            span(style="background:#fee2e2; color:#b91c1c; padding:4px 10px; font-size:12px; border-radius:20px;")
                              | Back in Stock

                        // Image
                        if product.image
                          tr
                            td(align="center" style="padding-bottom:12px;")
                              img(
                                src=product.image
                                alt=product.title
                                style="max-width:100%; border-radius:6px;"
                              )

                        // Title
                        tr
                          td(align="center" style="font-size:18px; font-weight:bold; color:#111; padding-bottom:8px;")
                            | #{product.title}

                        // Price
                        if product.price
                          tr
                            td(align="center" style="font-size:16px; font-weight:bold; color:#2563eb; padding-bottom:12px;")
                              | ₹#{product.price}

                        // CTA
                        tr
                          td(align="center" style="padding-top:10px;")
                            a(
                              href=productUrl
                              style="display:inline-block; padding:12px 20px; background:#2563eb; color:#ffffff; text-decoration:none; border-radius:6px; font-weight:bold;"
                            )
                              | 🛒 Buy Now

                        // Urgency
                        tr
                          td(align="center" style="padding-top:12px; color:#dc2626; font-size:13px; font-weight:bold;")
                            | Hurry! Limited stock available again.

                // ======================
                // OPTIONAL DESCRIPTION (OUTSIDE CARD)
                // ======================
                if product.description
                  div(style="margin-top:20px; font-size:14px; color:#4b5563; line-height:1.6;")
                    != product.description

            // Footer
            tr
              td(style="padding:16px; background:#f9fafb; font-size:12px; color:#6b7280; text-align:center;")

                p(style="margin:0 0 6px 0;")
                  | Need help? Contact us at 
                  a(
                    href=`mailto:${supportEmail || 'support@mitvana.in'}`
                    style="color:#2563eb; text-decoration:none;"
                  )
                    | #{supportEmail || 'support@mitvana.in'}

                p(style="margin:0;")
                  | © #{new Date().getFullYear()} #{appName || 'Mitvana'}. All rights reserved.